:root {
  --bg: #080c10;
  --surface: #0d1117;
  --card: #111820;
  --border: #1e2d3d;
  --accent: #00e5ff;
  --accent2: #ff6b35;
  --accent3: #a3ff6f;
  --accent4: #c084fc;
  --text: #e8edf2;
  --muted: #6b7a8d;
  --glow: 0 0 40px rgba(0, 229, 255, 0.15);
}

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-weight: 300;
  overflow-x: hidden;
  cursor: none;
}

/* Grid background */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(0, 229, 255, 0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 229, 255, 0.025) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
  z-index: 0;
}

/* ── CURSOR ──────────────────────────────────────────────────── */
.cursor {
  width: 12px;
  height: 12px;
  background: var(--accent);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9999;
  transition: transform 0.1s;
  mix-blend-mode: difference;
}

.cursor-ring {
  width: 36px;
  height: 36px;
  border: 1px solid var(--accent);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9998;
  transition: all 0.18s ease;
  opacity: 0.5;
}

/* ── NAV ──────────────────────────────────────────────────────── */
nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 18px 60px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(0, 229, 255, 0.06);
  background: rgba(8, 12, 16, 0.85);
}

.nav-logo {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.1rem;
  color: var(--accent);
  letter-spacing: 0.05em;
  text-decoration: none;
}

.nav-logo span {
  color: var(--muted);
}

.nav-links {
  display: flex;
  gap: 32px;
  list-style: none;
  align-items: center;
}

.nav-links a {
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  color: var(--muted);
  text-decoration: none;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: color 0.2s;
}

.nav-links a:hover {
  color: var(--accent);
}

.nav-blog {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  padding: 8px 18px;
  border: 1px solid var(--accent);
  color: var(--accent) !important;
  text-decoration: none;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: all 0.2s !important;
}

.nav-blog:hover {
  background: var(--accent);
  color: var(--bg) !important;
}

/* ── HERO ─────────────────────────────────────────────────────── */
#hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  position: relative;
  padding: 140px 60px 80px;
  overflow: hidden;
}

.hero-noise {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 60% 40%, rgba(0, 229, 255, 0.07) 0%, transparent 70%),
    radial-gradient(ellipse 50% 40% at 20% 80%, rgba(255, 107, 53, 0.05) 0%, transparent 60%);
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 1;
  max-width: 900px;
}

.hero-tag {
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  color: var(--accent);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 12px;
  opacity: 0;
  animation: fadeUp 0.7s forwards 0.1s;
}

.hero-tag::before {
  content: '';
  width: 32px;
  height: 1px;
  background: var(--accent);
}

.avail-dot {
  width: 8px;
  height: 8px;
  background: var(--accent3);
  border-radius: 50%;
  display: inline-block;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(163, 255, 111, 0.4); }
  50%       { box-shadow: 0 0 0 8px rgba(163, 255, 111, 0); }
}

.hero-h1 {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(3.5rem, 8vw, 7rem);
  line-height: 0.95;
  letter-spacing: -0.03em;
  margin-bottom: 32px;
  opacity: 0;
  animation: fadeUp 0.7s forwards 0.25s;
}

.name-outline {
  -webkit-text-stroke: 1px rgba(0, 229, 255, 0.4);
  color: transparent;
  display: block;
}

.hero-desc {
  font-size: 1.1rem;
  color: var(--muted);
  max-width: 560px;
  line-height: 1.7;
  margin-bottom: 48px;
  opacity: 0;
  animation: fadeUp 0.7s forwards 0.4s;
}

.hero-desc strong {
  color: var(--text);
  font-weight: 500;
}

.cursor-blink {
  animation: blink 1s infinite;
  color: var(--accent);
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

.hero-actions {
  display: flex;
  gap: 16px;
  align-items: center;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.7s forwards 0.55s;
}

.hero-stats {
  position: absolute;
  right: 60px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 32px;
  opacity: 0;
  animation: fadeIn 1s forwards 0.7s;
}

.stat {
  text-align: right;
}

.stat-num {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 2.2rem;
  color: var(--accent);
  line-height: 1;
}

.stat-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.62rem;
  color: var(--muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-top: 4px;
}

/* ── BUTTONS ──────────────────────────────────────────────────── */
.btn-primary {
  font-family: 'DM Mono', monospace;
  font-size: 0.8rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 14px 32px;
  background: var(--accent);
  color: var(--bg);
  border: none;
  text-decoration: none;
  transition: all 0.2s;
  clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  display: inline-block;
  cursor: none;
}

.btn-primary:hover {
  background: #fff;
  box-shadow: 0 0 30px rgba(0, 229, 255, 0.4);
}

.btn-ghost {
  font-family: 'DM Mono', monospace;
  font-size: 0.8rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 13px 32px;
  border: 1px solid var(--border);
  color: var(--muted);
  text-decoration: none;
  transition: all 0.2s;
  display: inline-block;
  cursor: none;
}

.btn-ghost:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.btn-ghost-green {
  border-color: rgba(163, 255, 111, 0.3);
  color: var(--accent3);
}

.btn-ghost-green:hover {
  border-color: var(--accent3);
  color: var(--accent3);
}

/* ── SECTIONS ─────────────────────────────────────────────────── */
section {
  position: relative;
  z-index: 1;
  padding: 100px 60px;
}

.section-border {
  border-top: 1px solid var(--border);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 64px;
}

.section-num {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  color: var(--accent);
  letter-spacing: 0.15em;
}

.section-header h2 {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 2.8rem;
  letter-spacing: -0.02em;
}

.section-line {
  flex: 1;
  height: 1px;
  background: var(--border);
}

/* ── ABOUT ────────────────────────────────────────────────────── */
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}

.about-text p {
  font-size: 1.05rem;
  line-height: 1.8;
  color: var(--muted);
  margin-bottom: 20px;
}

.about-text p strong {
  color: var(--text);
}

.skills-grid {
  display: grid;
  gap: 18px;
}

.skill-group-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent2);
  margin-bottom: 8px;
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  padding: 5px 12px;
  border: 1px solid var(--border);
  color: var(--muted);
  letter-spacing: 0.05em;
  transition: all 0.2s;
}

.tag:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(0, 229, 255, 0.05);
}

/* ── EXPERIENCE ───────────────────────────────────────────────── */
.exp-list {
  display: grid;
  gap: 0;
}

.exp-item {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 40px;
  padding: 48px 0;
  border-bottom: 1px solid var(--border);
}

.exp-item:last-child {
  border-bottom: none;
}

.exp-date {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: var(--accent);
  letter-spacing: 0.1em;
  margin-bottom: 8px;
}

.exp-company {
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  color: var(--muted);
}

.exp-role {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1.4rem;
  margin-bottom: 16px;
}

.exp-points {
  list-style: none;
  display: grid;
  gap: 10px;
}

.exp-points li {
  font-size: 0.92rem;
  color: var(--muted);
  padding-left: 20px;
  position: relative;
  line-height: 1.6;
}

.exp-points li::before {
  content: '▸';
  position: absolute;
  left: 0;
  color: var(--accent);
  font-size: 0.7rem;
  top: 3px;
}

.exp-tech {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 16px;
}

.tech-pill {
  font-family: 'DM Mono', monospace;
  font-size: 0.65rem;
  padding: 3px 10px;
  background: rgba(0, 229, 255, 0.06);
  border: 1px solid rgba(0, 229, 255, 0.15);
  color: var(--accent);
}

/* ── PROJECTS ─────────────────────────────────────────────────── */
.projects-filter {
  display: flex;
  gap: 8px;
  margin-bottom: 32px;
  flex-wrap: wrap;
}

.filter-btn {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 8px 18px;
  border: 1px solid var(--border);
  color: var(--muted);
  background: none;
  transition: all 0.2s;
  cursor: none;
}

.filter-btn.active,
.filter-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(0, 229, 255, 0.05);
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2px;
}

.project-card {
  background: var(--card);
  padding: 36px;
  border: 1px solid var(--border);
  position: relative;
  overflow: hidden;
  transition: all 0.3s;
  display: block;
  cursor: none;
}

.project-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(0, 229, 255, 0.04) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 0.3s;
}

.project-card:hover {
  border-color: rgba(0, 229, 255, 0.3);
  box-shadow: var(--glow);
}

.project-card:hover::before {
  opacity: 1;
}

.project-card:hover .proj-arrow {
  transform: translate(4px, -4px);
  opacity: 1;
}

.project-card.featured {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 48px;
}

.proj-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.proj-arrow {
  color: var(--accent);
  opacity: 0;
  transition: all 0.2s;
  font-size: 1.1rem;
  flex-shrink: 0;
}

.proj-num {
  font-family: 'DM Mono', monospace;
  font-size: 0.62rem;
  color: var(--muted);
  letter-spacing: 0.15em;
  margin-bottom: 16px;
}

.proj-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1.25rem;
  letter-spacing: -0.01em;
  margin-bottom: 6px;
}

.proj-sub {
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  color: var(--accent2);
  letter-spacing: 0.1em;
  margin-bottom: 14px;
}

.proj-desc {
  font-size: 0.88rem;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 20px;
}

.proj-stat {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 2rem;
  color: var(--accent3);
  line-height: 1;
}

.proj-stat-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.62rem;
  color: var(--muted);
  letter-spacing: 0.1em;
  margin-bottom: 16px;
}

.proj-links {
  display: flex;
  gap: 12px;
  margin-top: 16px;
  flex-wrap: wrap;
}

.proj-link {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
  text-decoration: none;
  border-bottom: 1px solid rgba(0, 229, 255, 0.3);
  padding-bottom: 2px;
  transition: border-color 0.2s;
}

.proj-link:hover {
  border-color: var(--accent);
}

.proj-side {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

/* ── CERTIFICATIONS ───────────────────────────────────────────── */
.cert-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}

.cert-card {
  background: var(--card);
  border: 1px solid var(--border);
  padding: 32px;
  position: relative;
  overflow: hidden;
  transition: border-color 0.3s;
}

.cert-card:hover {
  border-color: rgba(192, 132, 252, 0.4);
}

.cert-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 3px;
  height: 100%;
  background: var(--accent4);
  opacity: 0;
  transition: opacity 0.3s;
}

.cert-card:hover::after {
  opacity: 1;
}

.cert-issuer {
  font-family: 'DM Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent4);
  margin-bottom: 10px;
}

.cert-name {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 0.95rem;
  margin-bottom: 8px;
  line-height: 1.3;
}

.cert-skills {
  font-size: 0.8rem;
  color: var(--muted);
  line-height: 1.5;
}

.cert-badge {
  position: absolute;
  top: 24px;
  right: 24px;
  font-size: 1.4rem;
}

/* ── ACHIEVEMENTS ─────────────────────────────────────────────── */
.achieve-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}

.achieve-card {
  background: var(--card);
  border: 1px solid var(--border);
  padding: 40px;
  transition: border-color 0.3s;
}

.achieve-card:hover {
  border-color: rgba(163, 255, 111, 0.3);
}

.achieve-icon {
  font-size: 1.8rem;
  margin-bottom: 20px;
}

.achieve-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1rem;
  margin-bottom: 8px;
  color: var(--accent3);
}

.achieve-desc {
  font-size: 0.88rem;
  color: var(--muted);
  line-height: 1.6;
}

/* ── EDUCATION ────────────────────────────────────────────────── */
.edu-block {
  border: 1px solid var(--border);
  padding: 48px;
  background: var(--card);
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
  align-items: start;
}

.edu-degree {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1.6rem;
  letter-spacing: -0.02em;
  margin-bottom: 8px;
}

.edu-school {
  font-size: 1rem;
  color: var(--muted);
  margin-bottom: 16px;
}

.edu-courses {
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  color: var(--muted);
  line-height: 1.8;
}

.edu-year {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 3rem;
  color: rgba(0, 229, 255, 0.12);
  text-align: right;
  line-height: 1;
}

.edu-grad-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.62rem;
  color: var(--muted);
  text-align: right;
  margin-top: 4px;
  letter-spacing: 0.1em;
}

/* ── CONTACT ──────────────────────────────────────────────────── */
.contact-wrapper {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}

.contact-headline {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 3rem;
  line-height: 0.95;
  letter-spacing: -0.03em;
  margin-bottom: 20px;
}

.contact-headline span {
  color: var(--accent);
}

.contact-sub {
  font-size: 1rem;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 28px;
}

.contact-direct {
  display: grid;
  gap: 2px;
}

.direct-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px 20px;
  background: var(--card);
  border: 1px solid var(--border);
  text-decoration: none;
  color: var(--text);
  transition: all 0.2s;
  cursor: none;
}

.direct-link:hover {
  border-color: var(--accent);
  background: rgba(0, 229, 255, 0.04);
}

.direct-link-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.65rem;
  color: var(--muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.direct-link-val {
  font-size: 0.82rem;
}

.direct-link-arrow {
  color: var(--accent);
  font-size: 0.85rem;
}

.contact-form-section {
  display: grid;
  gap: 14px;
}

.form-header {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  color: var(--muted);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.form-group {
  display: grid;
  gap: 7px;
}

.form-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
}

.form-input,
.form-textarea {
  background: var(--card);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 13px 16px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.92rem;
  font-weight: 300;
  outline: none;
  transition: border-color 0.2s;
  width: 100%;
  resize: none;
}

.form-input:focus,
.form-textarea:focus {
  border-color: var(--accent);
  background: rgba(0, 229, 255, 0.02);
}

.form-input::placeholder,
.form-textarea::placeholder {
  color: var(--muted);
}

.form-textarea {
  min-height: 130px;
}

.form-submit {
  font-family: 'DM Mono', monospace;
  font-size: 0.8rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 16px 40px;
  background: var(--accent);
  color: var(--bg);
  border: none;
  cursor: none;
  transition: all 0.2s;
  clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  width: 100%;
  font-weight: 400;
}

.form-submit:hover {
  background: #fff;
  box-shadow: 0 0 30px rgba(0, 229, 255, 0.4);
}

.form-submit:disabled {
  opacity: 0.6;
}

.form-status {
  font-family: 'DM Mono', monospace;
  font-size: 0.73rem;
  text-align: center;
  padding: 12px;
  margin-top: 4px;
}

.form-status.success {
  color: var(--accent3);
  border: 1px solid rgba(163, 255, 111, 0.3);
}

.form-status.error {
  color: var(--accent2);
  border: 1px solid rgba(255, 107, 53, 0.3);
}

/* ── FOOTER ───────────────────────────────────────────────────── */
footer {
  padding: 40px 60px;
  border-top: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 1;
}

.footer-text {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  color: var(--muted);
  letter-spacing: 0.1em;
}

.footer-logo {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 0.9rem;
  color: var(--accent);
}

/* ── SCROLL REVEAL ────────────────────────────────────────────── */
.reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ── KEYFRAMES ────────────────────────────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ── SCROLLBAR ────────────────────────────────────────────────── */
::-webkit-scrollbar       { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border); }
::-webkit-scrollbar-thumb:hover { background: var(--accent); }

/* ── RESPONSIVE ───────────────────────────────────────────────── */
@media (max-width: 900px) {
  nav { padding: 14px 20px; }
  .nav-links { gap: 14px; }
  .hide-mob { display: none; }
  section { padding: 70px 20px; }
  #hero { padding: 110px 20px 70px; }
  .hero-stats { display: none; }
  .about-grid,
  .contact-wrapper { grid-template-columns: 1fr; gap: 40px; }
  .exp-item { grid-template-columns: 1fr; gap: 6px; }
  .projects-grid { grid-template-columns: 1fr; }
  .project-card.featured { grid-column: 1; grid-template-columns: 1fr; }
  .achieve-grid,
  .cert-grid { grid-template-columns: 1fr; }
  .edu-block { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
  footer { flex-direction: column; gap: 10px; text-align: center; }
}
